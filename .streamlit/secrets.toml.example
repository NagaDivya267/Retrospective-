# Copy this file to .streamlit/secrets.toml and fill in your own values.
# NEVER commit secrets.toml — it is already listed in .gitignore.

# -----------------------------------------------------------------
# Authentication is handled via credentials.json (also git-ignored).
# Place your Google Cloud service account JSON key at the root of
# the project as "credentials.json" before running the app.
#
# Only the Google Sheet ID is needed here.
# The ID is the long string in your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
# -----------------------------------------------------------------

[google_sheets]
spreadsheet_id = "your-google-spreadsheet-id"
